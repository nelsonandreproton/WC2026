# --- Telegram ---
# Get a token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# --- football-data.org ---
# Free API key: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-key
COMPETITION=WC

# --- Game rules ---
# Predictions lock this many minutes before each kickoff.
LOCK_MINUTES=15
# Champion bets lock at the opening match kickoff (ISO-8601 UTC).
CHAMPION_LOCK_UTC=2026-06-11T16:00:00Z

# --- Runtime ---
# SQLite path (overridden to /app/data/wc2026.db in docker-compose).
DB_PATH=data/wc2026.db
# Seconds between outbound DMs (throttling to respect Telegram limits).
DM_INTERVAL_SECONDS=0.2
# How often (minutes) to poll for results during match windows.
POLL_INTERVAL_MINUTES=5
